# Environment Variables Example
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control

# ============================================
# API Configuration
# ============================================
NEXT_PUBLIC_API_URL=https://rewardsuatapi.hireagent.co

# ============================================
# Verisoul Fraud Prevention
# ============================================
NEXT_PUBLIC_VERISOUL_API_KEY=your_verisoul_api_key_here
NEXT_PUBLIC_VERISOUL_BASE_URL=https://api.verisoul.ai
NEXT_PUBLIC_VERISOUL_PROJECT_ID=your_verisoul_project_id_here

# ============================================
# Firebase Configuration
# ============================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here

# ============================================
# Cloudflare Turnstile (CAPTCHA)
# ============================================
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# ============================================
# Stripe Payment Processing
# ============================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# ============================================
# App Version
# ============================================
NEXT_PUBLIC_APP_VERSION=V0.1.0

# ============================================
# AppLovin MAX / Google AdMob (iOS)
# ============================================
NEXT_PUBLIC_APPLOVIN_AD_UNIT_IOS_REWARDED=your_applovin_ios_rewarded_ad_unit_id
NEXT_PUBLIC_APPLOVIN_AD_UNIT_ANDROID_REWARDED=your_applovin_android_rewarded_ad_unit_id
NEXT_PUBLIC_ADMOB_APP_ID_IOS=your_admob_ios_app_id
NEXT_PUBLIC_ADMOB_APP_ID_ANDROID=your_admob_android_app_id

# ============================================
# Server-Side Only (DO NOT use NEXT_PUBLIC_ prefix)
# ============================================
# These are only used on the server and should NEVER be exposed to the client
JWT_SECRET=your_jwt_secret_here
