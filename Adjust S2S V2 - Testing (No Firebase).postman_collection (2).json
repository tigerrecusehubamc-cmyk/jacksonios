			"name": "2. V2 User Endpoints (JWT Auth)",
			"item": [
				{
					"name": "Get Configuration",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    pm.test('Config returned', function () {",
									"        const jsonData = pm.response.json();",
									"        pm.expect(jsonData.data.version).to.eql('2.0');",
									"        pm.expect(jsonData.data.requiresAppCheck).to.be.true;",
									"        pm.expect(jsonData.data.requiresFirebaseAuth).to.be.true;",
									"    });",
									"    console.log('✅ Config endpoint works with JWT');",
									"} else if (pm.response.code === 401) {",
									"    console.log('⚠️ Need to login first to get JWT token');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v2/adjust/config",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"v2",
								"adjust",
								"config"
							]
						},
						"description": "Get V2 configuration info. Requires JWT token (Firebase Auth disabled)."
					},
					"response": []
				},
				{
					"name": "Get Available S2S Event Tokens",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const jsonData = pm.response.json();",
									"    if (jsonData.data.events && jsonData.data.events.length > 0) {",
									"        // Save first event token for testing",
									"        pm.collectionVariables.set('event_token', jsonData.data.events[0].token);",
									"        console.log('✅ Event token saved:', jsonData.data.events[0].token);",
									"        console.log('📊 Total S2S events:', jsonData.data.count);",
									"    } else {",
									"        console.log('⚠️ No events found. Run: node scripts/import-adjust-events.js');",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v2/adjust/events",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"v2",
								"adjust",
								"events"
							],
							"query": [
								{
									"key": "category",
									"value": "survey",
									"description": "Optional: Filter by category",
									"disabled": true
								},
								{
									"key": "search",
									"value": "s2s_",
									"description": "Optional: Search by name",
									"disabled": true
