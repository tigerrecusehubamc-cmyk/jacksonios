				{
					"name": "Report Event - Level Complete",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    pm.test('Event reported successfully', function () {",
									"        const jsonData = pm.response.json();",
									"        pm.expect(jsonData.success).to.be.true;",
									"    });",
									"    console.log('✅ Event reported successfully');",
									"} else if (pm.response.code === 401) {",
									"    console.log('⚠️ Need to login first to get JWT token');",
									"} else if (pm.response.code === 400) {",
									"    console.log('⚠️ Validation error:', pm.response.json().error);",
									"} else if (pm.response.code === 403) {",
									"    console.log('⚠️ Campaign filter failed - user not from offerwall');",
									"}"
